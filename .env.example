# GMAT AI grading — copy this file to `.env` and fill in your key.
# `.env` is gitignored so your key is never committed.
#
#   cp .env.example .env
#   # then edit .env and set OPENAI_API_KEY

# OpenAI API key used by the AI flashcard grader / peer tutor (qt/aqt/gmat_ai.py).
# Without a key, AI grading stays off and term cards fall back to normal self-rating.
OPENAI_API_KEY=

# Optional overrides:
# GMAT_AI_MODEL=gpt-4o-mini
